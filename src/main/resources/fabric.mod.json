{
  "schemaVersion": 1,
  "id": "chatbridge",
  "version": "${version}",
  "name": "ChatBridge",
  "description": "Provides customizable formatting for bridge bot messages.",
  "authors": [
    "FanerXp"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/chatbridge-ws",
    "sources": "https://github.com/unknown-salt/chatbridge",
    "issues": "https://github.com/unknown-salt/chatbridge/issues"
  },
  "license": "MIT",
  "icon": "assets/chatbridge/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "value": "com.chatbridge.ChatBridge",
        "adapter": "kotlin"
      }
    ],
    "modmenu": [
      "com.chatbridge.config.ChatBridgeModMenu"
    ]
  },
  "mixins": [],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "~1.21.10",
    "java": ">=21",
    "fabric-api": "*",
    "fabric-language-kotlin": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.modrinth": "https://modrinth.com/mod/chatbridge-ws"
      }
    }
  }
}